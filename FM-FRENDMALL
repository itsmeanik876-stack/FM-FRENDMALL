<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FM.COM (FRND-MALL)</title>
<style>
body{font-family:Arial;margin:0;background:#f5f5f5}
header{background:black;color:white;padding:20px;text-align:center}
nav{background:#222;padding:10px;text-align:center}
nav a{color:white;margin:0 15px;text-decoration:none;font-weight:bold}
.hero{padding:60px;text-align:center;background:#111;color:white}
.section{padding:40px}
.products{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin-top:20px}
.card{background:white;border-radius:10px;padding:15px;text-align:center;box-shadow:0 5px 15px rgba(0,0,0,0.1)}
.card img{width:100%;border-radius:8px}
.price{color:green;font-weight:bold}
button{background:black;color:white;border:none;padding:10px 15px;border-radius:5px;cursor:pointer}
footer{background:black;color:white;text-align:center;padding:15px;margin-top:40px}
.admin{padding:40px;background:#fff}
input,select{padding:8px;margin:5px;width:100%;max-width:300px}
</style>
</head>
<body>

<header>
<h1>FM.COM (FRND-MALL)</h1>
<p>Boys T-Shirt | Caps | Pants | Fashion</p>
</header>

<nav>
<a href="#tshirt">T-Shirts</a>
<a href="#cap">Caps</a>
<a href="#pant">Pants</a>
<a href="#admin">Admin Upload</a>
</nav>

<section class="hero">
<h2>Welcome to FM.COM</h2>
<p>Best Boys Fashion Collection</p>
</section>

<!-- TSHIRT SECTION -->
<section id="tshirt" class="section">
<h2>👕 T‑Shirt Collection</h2>
<div class="products" id="tshirtProducts"></div>
</section>

<!-- CAP SECTION -->
<section id="cap" class="section">
<h2>🧢 Cap Collection</h2>
<div class="products" id="capProducts"></div>
</section>

<!-- PANT SECTION -->
<section id="pant" class="section">
<h2>👖 Pant Collection</h2>
<div class="products" id="pantProducts"></div>
</section>

<!-- ADMIN PANEL -->
<section id="admin" class="admin">
<h2>Admin Product Upload</h2>
<p>Admin Login (Only authorized admins can access)

<input type="text" id="loginUser" placeholder="Admin ID">
<input type="password" id="loginPass" placeholder="Password">
<button onclick="login()">Login</button>

<div id="uploadPanel" style="display:none;margin-top:20px">
<h3>Add Product</h3>

<input type="text" id="pname" placeholder="Product Name">
<input type="text" id="pprice" placeholder="Price">

<select id="pcategory">
<option value="tshirt">T‑Shirt</option>
<option value="cap">Cap</option>
<option value="pant">Pant</option>
</select>

<input type="file" id="pimage">
<br>
<button onclick="addProduct()">Upload Product</button>
</div>
</section>

<section style="padding:40px;text-align:center">
<h2>Order on WhatsApp</h2>
<a href="https://wa.me/8801847600112" target="_blank">
<button style="background:green">Chat on WhatsApp</button>
</a>
</section>

<footer>
<p>© 2026 FM.COM (FRND-MALL)</p>
</footer>

<script>
let products = JSON.parse(localStorage.getItem("fm_products") || "[]");

function displayProducts(){

const tshirtContainer=document.getElementById("tshirtProducts");
const capContainer=document.getElementById("capProducts");
const pantContainer=document.getElementById("pantProducts");


tshirtContainer.innerHTML="";
capContainer.innerHTML="";
pantContainer.innerHTML="";

products.forEach(p=>{

const card=document.createElement("div");
card.className="card";

card.innerHTML=`
<img src="${p.image}">
<h3>${p.name}</h3>
<p class="price">৳${p.price}</p>
<a href="https://wa.me/8801847600112?text=I want to order ${p.name}" target="_blank">
<button>Order on WhatsApp</button>
</a>`;

if(p.category==="tshirt") tshirtContainer.appendChild(card);
if(p.category==="cap") capContainer.appendChild(card);
if(p.category==="pant") pantContainer.appendChild(card);

});
}

function login(){
const u=document.getElementById("loginUser").value;
const p=document.getElementById("loginPass").value;

if((u==="admin1" && p==="1234") || (u==="admin2" && p==="5678")){

document.getElementById("uploadPanel").style.display="block";
sessionStorage.setItem("fm_admin_logged","true");
document.getElementById("loginUser").style.display="none";
document.getElementById("loginPass").style.display="none";
alert("Login successful");

}else{
alert("Wrong ID or Password");
}
}

function addProduct(){

const name=document.getElementById("pname").value;
const price=document.getElementById("pprice").value;
const category=document.getElementById("pcategory").value;
const file=document.getElementById("pimage").files[0];

const reader=new FileReader();

reader.onload=function(){

const product={
name:name,
price:price,
category:category,
image:reader.result
};

products.push(product);

localStorage.setItem("fm_products",JSON.stringify(products));

displayProducts();

// keep admin logged in without showing login again
if(sessionStorage.getItem("fm_admin_logged")==="true"){
 document.getElementById("uploadPanel").style.display="block";
 document.getElementById("loginUser").style.display="none";
 document.getElementById("loginPass").style.display="none";
}

};

if(file){reader.readAsDataURL(file);} 

}

displayProducts();
</script>

</body>
</html>
